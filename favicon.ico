table{border-collapse:collapse;width:100%;margin:10px 0}
th,td{border:1px solid var(--border);padding:10px 14px;font-size:14px;text-align:left}
th{background:var(--surface);color:var(--muted);width:32%;font-weight:600}
a{color:var(--amber)}
footer{text-align:center;font-size:12px;color:var(--muted);border-top:1px solid var(--border);padding-top:20px;margin-top:48px}
footer a{color:var(--muted);margin:0 8px}
</style>
